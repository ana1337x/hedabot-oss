# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.

# -----------------------------------------------------------------------
# Discord
# -----------------------------------------------------------------------

# Your bot's token from the Discord Developer Portal.
# Never share this — it gives full control of your bot.
# Where to get it: https://discord.com/developers/applications → your app → Bot → Token
DISCORD_TOKEN=

# Optional. discord.py reads the app ID from the token automatically.
# Only set this if you run into issues with command registration.
DISCORD_CLIENT_ID=

# -----------------------------------------------------------------------
# Deepgram (transcription)
# -----------------------------------------------------------------------

# Your API key from console.deepgram.com.
# The free tier includes $200 of credit — more than enough to get started.
DEEPGRAM_API_KEY=

# -----------------------------------------------------------------------
# Supabase (database)
# -----------------------------------------------------------------------

# Your project URL. Found in: Supabase dashboard → Project Settings → API → Project URL
SUPABASE_URL=

# The service role key — NOT the anon key.
# Found in: Supabase dashboard → Project Settings → API → service_role (keep this secret)
# The bot needs this to write transcripts to your database.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------
# Optional settings
# -----------------------------------------------------------------------

# How long (in seconds) the bot waits for a voice connection before giving up.
# Default is 15 seconds. Increase this if you're on a slow network.
# VOICE_CONNECTION_TIMEOUT=15
